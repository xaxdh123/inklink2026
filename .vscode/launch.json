{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Roll_Splice",
            "type": "debugpy",
            "request": "launch",
            "program": "layout_center/Roll_Splice/run.py",
            "console": "integratedTerminal"
        },
        {
            "name": "proofts",
            "type": "debugpy",
            "request": "launch",
            "program": "layout_center/ProofTS/main.py",
            "console": "integratedTerminal"
        },
        {
            "name": "main",
            "type": "debugpy",
            "request": "launch",
            "program": "./main.py",
            "console": "integratedTerminal"
        },
        {
            "name": "sub_mod",
            "type": "debugpy",
            "request": "launch",
            "program": "./sub_module.py",
            "console": "integratedTerminal",
            "args": [
                "${input:mode}"
            ]
        },
    ],
    "inputs": [
        {
            "id": "mode",
            "type": "pickString",
            "description": "选择启动模块",
            "options": [
                "AuditCenter",
                "CustomerService",
                "DesignCenter",
                "FloatingPlugin",
                "LayoutCenter",
                "SystemSetting",
                "ThirdParty",
            ],
            "default": "float"
        }
    ]
}